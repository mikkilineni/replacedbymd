# ReplaceByMd Environment Variables
# Copy this to .env.local and fill in your values

# Required — Anthropic API key for Claude calls
ANTHROPIC_API_KEY=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

# Profile extraction service (optional — falls back to web search)
