# ReplaceByMd Environment Variables
# Copy this to .env.local and fill in your values

# Required — Anthropic API key for Claude calls
ANTHROPIC_API_KEY=

# Profile extraction service (optional — falls back to web search)
PROFILE_EXTRACTOR_URL=
PROFILE_EXTRACTOR_API_KEY=

# Mode: "fast" (haiku, no web search) or "deep" (sonnet + web search)
ROAST_MODE=deep

# Models
CLAUDE_MODEL=claude-haiku-4-5-20251001       # used when ROAST_MODE=fast
CLAUDE_MODEL_DEEP=claude-sonnet-4-6          # used when ROAST_MODE=deep

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
